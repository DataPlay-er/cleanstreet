# Example environment file for the auth service
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to git

# Application environment
ENVIRONMENT=development
DEBUG=true

# PostgreSQL database connection
# Replace with your actual database credentials
DATABASE_URL=postgresql://cleansight:your_secure_password@localhost:5432/cleansight_db

# Redis connection
REDIS_URL=redis://localhost:6379/0

# JWT secret key for signing tokens
# IMPORTANT: Generate a new one for production
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your_secure_jwt_secret_key_at_least_64_characters_long

# JWT algorithm and token expiration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=900

# CORS allowed origins (adjust for your frontend domain)
CORS_ORIGINS=["http://localhost:5173"]
